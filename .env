DB_HOST=localhost
DB_PORT=8095
DB_USER=admin
DB_PASSWORD=password
DB_NAME=app
SERVER_PORT=8090
JWT_SECRET=secret
GRPC_PORT=8099

# server certs
GRPC_TLS_CERT=certs/server.crt
GRPC_TLS_KEY=certs/server.key
